# Copy this file to .env and fill in your values.

# Free football-data.org API token: https://www.football-data.org/client/register
# Free tier includes the FIFA World Cup permanently (the maintainer has
# publicly committed to this), 10 requests/minute -- far more than enough
# since this app only calls the API when someone clicks "Refresh Results".
FOOTBALL_DATA_TOKEN=your_token_here

# Competition code. WC = FIFA World Cup. (Others: CL, PL, BL1, SA, PD,
# FL1, ELC, PPL, DED, BSA, EC -- see football-data.org docs for the
# full free-tier list.)
COMPETITION_CODE=WC

# Port the server listens on locally.
PORT=8787

# Optional shared secret. If set, /sync and /admin/* routes require
# header "x-admin-key: <this value>". Leave blank to disable (fine for a
# private tunnel URL only you know, but a real secret is better).
ADMIN_KEY=

# Minutes after kickoff that predictions lock (matches the frontend's
# stated rule: "Predictions lock 5 minutes after kickoff").
PREDICTION_LOCK_MINUTES=5
EOF
echo done